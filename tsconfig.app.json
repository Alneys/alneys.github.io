{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/types/*.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "components.d.ts",
    "auto-imports.d.ts"
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    // ---- Customizations ----

    // Global scope types.
    "types": ["element-plus/global"],

    // TS6 migration safety: explicitly disable to avoid errors on side-effect imports
    // (e.g. import 'unfonts.css', import 'nprogress/nprogress.css')
    // Remove this after verifying all side-effect imports are properly handled.
    "noUncheckedSideEffectImports": false
  }
}
