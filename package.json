{
  "name": "alneys-github-pages",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:style": "stylelint --fix \"src/**/*.{scss,vue}\"",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm type-check",
    "commit-msg": "node scripts/verify-commit.js"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": "eslint --fix --cache",
    "src/**/*.{scss,vue}": "stylelint --fix",
    "src/**/*.{ts,vue,scss}": "prettier --write --experimental-cli"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "~2.3.2",
    "@fontsource-variable/inconsolata": "~5.2.8",
    "@fontsource-variable/noto-sans-jp": "~5.2.10",
    "@fontsource-variable/noto-sans-sc": "~5.2.10",
    "@vueuse/core": "^14.2.1",
    "cheerio": "~1.2.0",
    "crypto-js": "^4.2.0",
    "echarts": "~6.0.0",
    "element-plus": "~2.14.2",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "sm-crypto": "^0.4.0",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "~1.16.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/crypto-js": "^4.2.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@types/nprogress": "^0.2.3",
    "@types/sm-crypto": "^0.3.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/eslint-plugin": "^1.6.20",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "~10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.4",
    "sass": "^1.99.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.13.0",
    "stylelint-config-clean-order": "^10.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-fonts": "^2.0.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  }
}
